# ---- Build stage --------------------------------------------------------
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=linux \
    go build -trimpath \
    -ldflags "-s -w -X github.com/VRCDN/guiltyspark/internal/common/models.Version=${VERSION}" \
    -o /out/guiltyspark-agent \
    ./cmd/agent

# ---- Runtime stage ------------------------------------------------------
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /out/guiltyspark-agent /usr/local/bin/guiltyspark-agent
COPY configs/agent.yaml /etc/guiltyspark/agent.yaml

RUN mkdir -p /var/lib/guiltyspark /var/log/guiltyspark \
 && chmod 755 /var/lib/guiltyspark

VOLUME ["/var/lib/guiltyspark", "/etc/guiltyspark", "/var/log", "/run/log"]

ENTRYPOINT ["guiltyspark-agent"]
CMD ["-config", "/etc/guiltyspark/agent.yaml"]
